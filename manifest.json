{
   "action": {
      "default_popup": "popup/popup.html",
      "default_title": "AdShield Pro"
   },
   "background": {
      "service_worker": "background/service_worker.js"
   },
   "content_scripts": [ {
      "all_frames": false,
      "js": [ "content/element-picker.js" ],
      "matches": [ "<all_urls>" ],
      "run_at": "document_idle"
   } ],
   "declarative_net_request": {
      "rule_resources": [ {
         "enabled": true,
         "id": "yt_rules",
         "path": "rules/rules_yt.json"
      }, {
         "enabled": true,
         "id": "general_rules",
         "path": "rules/rules_general.json"
      } ]
   },
   "description": "__MSG_appDesc__",
   "host_permissions": [ "<all_urls>" ],
   "icons": {
      "128": "icons/icon128.png",
      "16": "icons/icon16.png",
      "24": "icons/icon24.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
   },
   "manifest_version": 3,
   "name": "__MSG_appName__",
   "default_locale": "tr",
   "permissions": [ "declarativeNetRequest", "declarativeNetRequestFeedback", "storage", "scripting", "activeTab", "tabs", "alarms" ],
   "update_url": "https://clients2.google.com/service/update2/crx",
   "version": "2.1",
   "web_accessible_resources": [ {
      "resources": [ "content/element-picker.css" ],
      "matches": [ "<all_urls>" ]
   } ]
}
